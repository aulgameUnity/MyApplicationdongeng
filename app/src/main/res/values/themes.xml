<resources>
    <!-- Tema dasar aplikasi. -->
    <style name="Theme.CeritaDongeng" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Warna utama aplikasi yang muncul pada elemen UI paling dominan -->
        <item name="colorPrimary">@color/pink</item>
        <!-- Variasi dari warna utama -->
        <item name="colorPrimaryVariant">@color/pink</item>
        <!-- Warna untuk teks atau ikon yang muncul di atas warna utama -->
        <item name="colorOnPrimary">@color/white</item>
        <!-- Warna sender yang digunakan sebagai aksen (seperti tombol atau switch) -->
        <item name="colorSecondary">@color/pink</item>
        <!-- Variasi dari warna sekunder -->
        <item name="colorSecondaryVariant">@color/pink</item>
        <!-- Warna untuk teks atau ikon yang muncul di atas warna sekunder -->
        <item name="colorOnSecondary">@color/black</item>
        <!-- Warna untuk bilah status di bagian paling atas layar ponsel -->
        <item name="android:statusBarColor">@color/pink</item>
        <!-- Jenis font (
        huruf) yang digunakan secara default di seluruh aplikasi -->
        <item name="android:fontFamily">@font/next_sunday</item>
    </style>

    <!-- Tema khusus untuk tampilan pencarian (SearchView).
         Menggunakan ThemeOverlay agar tidak terjadi konflik atribut. -->
    <style name="SearchView" parent="ThemeOverlay.AppCompat.Dark">
        <!-- Warna teks saat pengguna mengetik di kotak pencarian -->
        <item name="android:editTextColor">@android:color/white</item>
        <!-- Warna teks petunjuk (hint) seperti "Cari di sini..." -->
        <item name="android:textColorHint">@android:color/white</item>
        <!-- Membuat teks di dalam pencarian menjadi tebal -->
        <item name="android:textStyle">bold</item>
    </style>
</resources>